<manifest version="1.0" type="device">

    <!-- PQ: service runs 2.0-2.15 but manifest only declares 2.15 -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.pq</name>
        <transport>hwbinder</transport>
        <version>2.14</version>
        <version>2.15</version>
        <interface>
            <name>IPictureQuality</name>
            <instance>default</instance>
        </interface>
        <fqname>@2.14::IPictureQuality/default</fqname>
        <fqname>@2.15::IPictureQuality/default</fqname>
    </hal>

    <!-- mtkpower: 1.0 and 1.1 running but missing from manifest -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.mtkpower</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <version>1.1</version>
        <interface>
            <name>IMtkPerf</name>
            <instance>default</instance>
        </interface>
        <interface>
            <name>IMtkPower</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.0::IMtkPerf/default</fqname>
        <fqname>@1.0::IMtkPower/default</fqname>
        <fqname>@1.1::IMtkPerf/default</fqname>
        <fqname>@1.1::IMtkPower/default</fqname>
    </hal>

    <!-- nvram: 1.0 running but missing from manifest -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.nvram</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>INvram</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.0::INvram/default</fqname>
    </hal>

    <!-- apuware: completely missing from manifest -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.apuware.apusys</name>
        <transport>hwbinder</transport>
        <version>2.0</version>
        <version>2.1</version>
        <interface>
            <name>INeuronApusys</name>
            <instance>default</instance>
        </interface>
        <fqname>@2.0::INeuronApusys/default</fqname>
        <fqname>@2.1::INeuronApusys/default</fqname>
    </hal>

    <hal format="hidl">
        <name>vendor.mediatek.hardware.apuware.hmp</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>IApuwareHmp</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.0::IApuwareHmp/default</fqname>
    </hal>

    <hal format="hidl">
        <name>vendor.mediatek.hardware.apuware.utils</name>
        <transport>hwbinder</transport>
        <version>2.0</version>
        <interface>
            <name>IApuwareUtils</name>
            <instance>default</instance>
        </interface>
        <fqname>@2.0::IApuwareUtils/default</fqname>
    </hal>

    <!-- lbs: completely missing from manifest -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.lbs</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>ILbs</name>
            <instance>AgpsDebugInterface</instance>
            <instance>AgpsInterface</instance>
            <instance>mtk_agps2framework</instance>
            <instance>mtk_framework2agps</instance>
            <instance>mtk_lbs_log_v2s</instance>
            <instance>mtk_mnld2debugService</instance>
        </interface>
        <fqname>@1.0::ILbs/AgpsInterface</fqname>
        <fqname>@1.0::ILbs/mtk_agps2framework</fqname>
        <fqname>@1.0::ILbs/mtk_framework2agps</fqname>
    </hal>

    <!-- camera.bgservice: 1.0 running but manifest only has 1.1 -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.camera.bgservice</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>IBGService</name>
            <instance>internal/0</instance>
        </interface>
        <fqname>@1.0::IBGService/internal/0</fqname>
    </hal>

</manifest>

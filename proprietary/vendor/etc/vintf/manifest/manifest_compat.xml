<manifest version="1.0" type="device">

    <!-- pq: service runs 2.0-2.15 via extension chain
         manifest.xml only declares 2.15, GSIs request 2.14 -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.pq</name>
        <transport>hwbinder</transport>
        <version>2.14</version>
        <version>2.15</version>
        <interface>
            <name>IPictureQuality</name>
            <instance>default</instance>
        </interface>
        <fqname>@2.14::IPictureQuality/default</fqname>
        <fqname>@2.15::IPictureQuality/default</fqname>
    </hal>

    <!-- mtkpower: 1.0 and 1.1 running, manifest.xml only declares 1.2 -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.mtkpower</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <version>1.1</version>
        <interface>
            <name>IMtkPerf</name>
            <instance>default</instance>
        </interface>
        <interface>
            <name>IMtkPower</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.0::IMtkPerf/default</fqname>
        <fqname>@1.0::IMtkPower/default</fqname>
        <fqname>@1.1::IMtkPerf/default</fqname>
        <fqname>@1.1::IMtkPower/default</fqname>
    </hal>

    <!-- nvram: 1.0 running, manifest.xml only declares 1.1 -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.nvram</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>INvram</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.0::INvram/default</fqname>
    </hal>

    <!-- camera.bgservice: 1.0 running, manifest.xml only declares 1.1 -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.camera.bgservice</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>IBGService</name>
            <instance>internal/0</instance>
        </interface>
        <fqname>@1.0::IBGService/internal/0</fqname>
    </hal>

</manifest>

    <!-- graphics.allocator AIDL: GSI servicemanager requests this -->
    <hal format="aidl">
        <name>android.hardware.graphics.allocator</name>
        <interface>
            <name>IAllocator</name>
            <instance>default</instance>
        </interface>
    </hal>
